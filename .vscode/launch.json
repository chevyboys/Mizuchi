{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Program",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "program": "${workspaceFolder}/bot.js"
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Attach to Remote Prod",
      "address": "127.0.0.1",
      "port": 9229,
      "localRoot": "${workspaceFolder}",
      "remoteRoot": "/opt/mizuchi"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Register Commands",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "program": "${workspaceFolder}/register_commands.js"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Anathema Bot",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "program": "${workspaceFolder}/bot_anathema.js"
    },
  ]
}